generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── HOSPITAL ACCOUNT (credit tracking — no registration required) ────────────

model HospitalAccount {
  id             String              @id @default(cuid())
  email          String              @unique
  freeLeadsUsed  Int                 @default(0)
  creditBalance  Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  transactions   CreditTransaction[]
}

model CreditTransaction {
  id                  String          @id @default(cuid())
  hospitalEmail       String
  hospital            HospitalAccount @relation(fields: [hospitalEmail], references: [email])
  type                String          // "free_lead" | "paid_lead" | "purchase"
  credits             Int             // negative for deductions, positive for purchases
  amountPaid          Int?            // in paise (purchase only)
  razorpayOrderId     String?
  razorpayPaymentId   String?
  inquiryId           String?
  createdAt           DateTime        @default(now())
}

// ─── INQUIRY ──────────────────────────────────────────────────────────────────

model Inquiry {
  id             String   @id @default(cuid())
  inquiryNumber  String   @unique
  guestName      String?
  guestEmail     String?
  guestPhone     String?
  guestCountry   String?
  guestLanguage  String?  @default("en")
  treatmentName  String?
  medicalSummary String?
  urgency        String   @default("routine")
  source         String   @default("web_form")
  status         String   @default("new")
  internalNotes     String?
  chatContext       String?
  leadToken         String?  @unique
  networkEmailedAt  DateTime?
  acceptedByEmail   String?
  acceptedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
